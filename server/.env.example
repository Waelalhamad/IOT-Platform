PORT=4000
NODE_ENV=production

# MongoDB — use Docker internal hostname in prod
MONGO_URI=mongodb://admin:STRONG_PASSWORD@mongodb:27017/esp_monitor?authSource=admin

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MQTT
MQTT_BROKER_URL=mqtt://emqx:1883
MQTT_USERNAME=esp-backend
MQTT_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# EMQX HTTP auth hook secret — must match emqx.conf
EMQX_AUTH_SECRET=REPLACE_WITH_32_CHAR_RANDOM_HEX

# Your domain
CORS_ORIGIN=https://yourdomain.com

SENSOR_READING_TTL_DAYS=30

# Must be true in production (requires HTTPS)
COOKIE_SECURE=true

# Redis (optional)
REDIS_URL=redis://:REDIS_PASSWORD@redis:6379
